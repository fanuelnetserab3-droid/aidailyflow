# Kopiera den här filen till .env och fyll i värdena

# Anthropic API-nyckel (krävs)
ANTHROPIC_API_KEY=sk-ant-...

# Databas (Railway fyller i denna automatiskt — lämna tom lokalt för SQLite)
DATABASE_URL=

# JWT-hemlighet — generera en slumpmässig sträng, t.ex.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=din-hemliga-nyckel-här

# Port (Railway sätter denna automatiskt)
PORT=8000
